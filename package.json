{
  "name": "depcheck-ai",
  "version": "0.1.0",
  "description": "AI that reads your dependencies — tells you what's broken, deprecated, or risky",
  "keywords": [
    "dependency-checker",
    "npm-audit",
    "health-score",
    "cli",
    "developer-tools",
    "package-registry",
    "supply-chain-security"
  ],
  "homepage": "https://github.com/FMATheNomad/depcheck-ai#readme",
  "bugs": {
    "url": "https://github.com/FMATheNomad/depcheck-ai/issues"
  },
  "type": "module",
  "license": "MIT",
  "author": "FMATheNomad",
  "bin": {
    "depcheck-ai": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "src/github-action/action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "chalk": "^5.6.2",
    "ora": "^9.4.1",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.2",
    "@types/semver": "^7.7.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FMATheNomad/depcheck-ai.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
